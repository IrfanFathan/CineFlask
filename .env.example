# CineLocal Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
HOST_IP=192.168.1.45        # Replace with YOUR LAN IP (see instructions.md Step 1)

# Security
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_characters_please

# IMDb Metadata API via OMDB (get free key at https://www.omdbapi.com/apikey.aspx)
IMDB_API_KEY=your_omdb_api_key_here

# Upload Configuration (optional - defaults shown)
MAX_FILE_SIZE_GB=50         # Maximum video file size in GB
CHUNK_SIZE_MB=5             # Upload chunk size in MB
